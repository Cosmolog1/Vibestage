{% extends 'base.admin.html.twig' %}

{% block title %}Menu Artiste{% endblock %}

{% block section %}
  <div class="admin-content bg-white py-5">
      <div class="container">
          <h2 class="text-center mb-4">Menu Artiste</h2>

          <div class="table-responsive">
              <table class="table table-striped table-bordered text-center">
                  <thead class="thead-dark">
                      <tr>
                          <th scope="col"><a href="{{ path('admin_artiste_add') }}" class="btn btn-success btn-sm">Ajouter</a></th>
                          <th scope="col">Artiste</th>
                          <th scope="col">Voir</th>
                          <th scope="col">Supprimer</th>
                          <th scope="col">Editer</th>
                      </tr>
                  </thead>
                  <tbody>
                      {% for artiste in artistes %}
                          <tr>
                              <th scope="row">{{ artiste.id }}</th>
                              <td>{{ artiste.name }}</td>
                              <td>
                                  <a href="{{ path('admin_artiste_show', {'id': artiste.id}) }}" class="btn btn-primary btn-sm">Voir</a>
                              </td>
                              <td>
                                  <a href="{{ path('admin_artiste_delete', {'id': artiste.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                              </td>
                              <td>
                                  <a href="{{ path('admin_artiste_edit', {'id': artiste.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                              </td>
                          </tr>
                      {% else %}
                          <tr>
                              <td colspan="5">Aucun artiste trouvé</td>
                          </tr>
                      {% endfor %}
                  </tbody>
              </table>
          </div>
      </div>
    </div>
  </div>

{% endblock %}