{% extends 'base.admin.html.twig' %}

{% block title %}Hello AdminIngredientController!{% endblock %}

{% block section %}
<div class="admin-content bg-white py-5">
  <div class="container">
    <h2 class="text-center mb-4">Menu Categorie</h2>
      <div class="table-responsive">
          <table class="table table-striped table-bordered text-center">
              <thead class="thead-dark">
                  <tr>
                      <th scope="col">
                          <a href="{{ path('admin_category_add') }}" class="btn btn-success btn-sm">Ajouter</a>
                      </th>
                      <th scope="col">Musique</th>
                      <th scope="col">Voir</th>
                      <th scope="col">Supprimer</th>
                      <th scope="col">Editer</th>
                  </tr>
              </thead>
              <tbody>
                  {% for category in categories %}
                      <tr>
                          <th scope="row">{{ category.id }}</th>
                          <td>{{ category.name }}</td>
                          <td>
                              <a href="{{ path('admin_category_show', {'id': category.id}) }}" class="btn btn-primary btn-sm">Voir</a>
                          </td>
                          <td>
                              <a href="{{ path('admin_category_delete', {'id': category.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                          </td>
                          <td>
                              <a href="{{ path('admin_category_edit', {'id': category.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                          </td>
                      </tr>
                  {% else %}
                      <tr>
                          <td colspan="5">Aucune musique trouvée</td>
                      </tr>
                  {% endfor %}
              </tbody>
          </table>
      </div>
  </div>
</div>
{% endblock %}