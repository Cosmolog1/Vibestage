{% extends 'base.admin.html.twig' %}

{% block title %}Hello AdminIngredientController!{% endblock %}

{% block section %}
  <div class="admin-content bg-white py-5">
      <div class="container">
          <h2 class="text-center mb-4">Menu Localisation</h2>

          <div class="table-responsive">
              <table class="table table-striped table-bordered text-center">
                  <thead class="thead-dark">
                      <tr>
                          <th scope="col">
                              <a href="{{ path('admin_location_add') }}" class="btn btn-success btn-sm">Ajouter</a>
                          </th>
                          <th scope="col">Pays</th>
                          <th scope="col">Ville</th>
                          <th scope="col">Voir</th>
                          <th scope="col">Supprimer</th>
                          <th scope="col">Editer</th>
                      </tr>
                  </thead>
                  <tbody>
                      {% for location in locations %}
                          <tr>
                              <th scope="row">{{ location.id }}</th>
                              <td>{{ location.country }}</td>
                              <td>{{ location.city }}</td>
                              <td>
                                  <a href="{{ path('admin_location_show', {'id': location.id}) }}" class="btn btn-primary btn-sm">Voir</a>
                              </td>
                              <td>
                                  <a href="{{ path('admin_location_delete', {'id': location.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                              </td>
                              <td>
                                  <a href="{{ path('admin_location_edit', {'id': location.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                              </td>
                          </tr>
                      {% else %}
                          <tr>
                              <td colspan="6">Aucune localisation trouvée</td>
                          </tr>
                      {% endfor %}
                  </tbody>
              </table>
          </div>
      </div>
  </div>
{% endblock %}
