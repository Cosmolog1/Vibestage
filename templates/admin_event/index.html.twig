{% extends 'base.admin.html.twig' %}

{% block title %}Hello AdminIngredientController!{% endblock %}

{% block section %}
<div class="admin-content bg-white py-5">
    <div class="container">
        <h2 class="text-center mb-4">Menu Evenement</h2>

        <div class="table-responsive">
            <table class="table table-striped table-bordered text-center">
                <thead class="thead-dark">
                    <tr>
                        <th scope="col">
                            <a href="{{ path('admin_event_add') }}" class="btn btn-success btn-sm">Ajouter</a>
                        </th>
                        <th scope="col">Evenement</th>
                        <th scope="col">Voir</th>
                        <th scope="col">Supprimer</th>
                        <th scope="col">Editer</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        <tr>
                            <th scope="row">{{ event.id }}</th>
                            <td>{{ event.name }}</td>
                            <td>
                                <a href="{{ path('admin_event_show', {'id': event.id}) }}" class="btn btn-primary btn-sm">Voir</a>
                            </td>
                            <td>
                                <a href="{{ path('admin_event_delete', {'id': event.id}) }}" class="btn btn-danger btn-sm">Supprimer</a>
                            </td>
                            <td>
                                <a href="{{ path('admin_event_edit', {'id': event.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">Aucun event trouvé</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}