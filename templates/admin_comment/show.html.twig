{% extends 'base.admin.html.twig' %}

{% block title %}Hello AdminCategoryController!{% endblock %}

{% block section %}
<div class="d-flex justify-content-center align-items-start min-vh-100 bg-light py-3">
    <div class="container col-md-6 p-4 bg-white rounded shadow my-5">
        <h2 class="text-center mb-4">Détails du Commentaire</h2>

        <p><strong>Utilisateur :</strong> {{ comment.user ? comment.user.pseudo : 'Anonyme' }}</p>
        <p><strong>Artiste :</strong> {{ comment.artiste ? comment.artiste.name : 'Aucun' }}</p>
        <p><strong>Événement :</strong> {{ comment.event ? comment.event.name : 'Aucun' }}</p>
        <p><strong>Contenu :</strong><br>{{ comment.content }}</p>

        <p><strong>Créé le :</strong> {{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : 'Inconnu' }}</p>
        <p><strong>Dernière mise à jour :</strong> {{ comment.updateAt ? comment.updateAt|date('d/m/Y H:i') : 'Inconnue' }}</p>
    </div>
</div>
{% endblock %}